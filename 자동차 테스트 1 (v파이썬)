# 5. UI 컨트롤러 배치 및 가이드 함수
scene.append_to_caption("<div style='clear:both;'></div>\n=== 제어판 ===\n\n")

def get_brake_guide(mu):
    if mu < 0.2: return "❄️ [빙판길] 미끄러짐 위험 극도로 높음"
    elif mu < 0.4: return "🌧️ [빗길/수막현상] 제동 거리 크게 증가"
    elif mu < 0.7: return "🏜️ [정상 도로] 일반적인 아스팔트 제동 수준"
    elif mu < 1.2: return "⚡ [급제동] 고성능 브레이크 패드 작동 수준"
    else: return "🔥 [최대 제동] 레이싱카 수준의 고접지력 슬릭 타이어"

def get_car_type(mass):
    if mass <= 1200: return "경차 (예: 모닝, 레이)"
    elif mass <= 1800: return "준중형/중형 세단 (예: 아반떼, 쏘나타)"
    elif mass <= 2500: return "대형 SUV/픽업트럭 (예: 팰리세이드, 카니발)"
    elif mass <= 5000: return "소형 트럭/마이크로버스 (예: 포터, 카운티)"
    elif mass <= 12000: return "대형 버스/중형 트럭 (예: 시내버스, 5톤 트럭)"
    else: return "대형 트럭/대형 덤프트럭 (25톤 카고 등)"

def set_mass(s):
    if running: return 
    global m_val, car, current_front_offset
    m_val = s.value
    car_type = get_car_type(m_val)
    car_type_txt.text = f"<span style='font-size: 12px; color: #666;'>[차종 가이드] {car_type}</span><br>"
    mass_txt.text = f" 차량 질량: {m_val:,} kg ({m_val/1000:.2f} t)"
    car.visible = False
    car, current_front_offset = build_car(m_val, START_FRONT_X)

def set_speed(s):
    global v_kmh  
    v_kmh = s.value
    speed_txt.text = f" 초기 속도: {v_kmh:>3} km/h"

def set_friction(s):
    global mu_val
    mu_val = s.value  
    guide = get_brake_guide(mu_val)
    fric_txt.text = f" 브레이크 강도(마찰 계수): {mu_val:.2f} <span style='font-size:12px; color:#cc6600;'>[{guide}]</span>"

def run_button(b):
    global running, car
    if not running and test_count <= 10: 
        car.visible = False
        car, current_front_offset = build_car(m_val, START_FRONT_X)
        v_ms = v_kmh / 3.6
        car.v = vec(v_ms, 0, 0)
        result_txt.text = f"<h3><b>[테스트 결과] {test_count}회차 진행 중...</b></h3>"
        running = True

def reset_button(b):
    global running, car, current_front_offset
    running = False 
    car.visible = False
    car, current_front_offset = build_car(m_val, START_FRONT_X)
    car.v = vec(0, 0, 0)
    if test_count <= 10:
        result_txt.text = f"<h3><b>[테스트 결과] {test_count}회차 대기 중...</b></h3>"

button(text="▶ 테스트 시작", bind=run_button)
