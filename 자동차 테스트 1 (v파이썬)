# 6. 메인 루프
dt = 0.01
while True:
    rate(100)
    
    if running:
        current_mu = mu_val 
        current_m = m_val
        
        while True:
            rate(100)
            if not running: break
            current_nose_x = car.pos.x + current_front_offset
            
            # [제동 구간 연산]
            if current_nose_x >= brake_start_x:
                friction_force = -current_mu * current_m * g
                a_x = friction_force / current_m
                car.v.x = car.v.x + a_x * dt
                
                # 완전히 멈췄을 때 (안전 정지 성공)
                if car.v.x <= 0:
                    car.v.x = 0
                    result_txt.text = f"<h2 style='color: green;'><b>[안전 정지] {test_count}회차 - 벽에 부딪히기 전에 안전하게 멈췄습니다! (충격량: 0 N·s)</b></h2>"
                    
                    # Y축이 250이므로 안전정지 시 바닥에 살짝 인지될 만한 수준인 5 고정 입력
                    zero_indicator = 5.0
                    bar_chart.plot(test_count, zero_indicator)
                    
                    test_count += 1
                    running = False
                    break 
            
            # 물리적 이동 업데이트
            car.pos = car.pos + car.v * dt
            
            # [충돌 연산]
            if current_nose_x >= wall.pos.x - 0.25:
                car.pos.x = (wall.pos.x - 0.25) - current_front_offset
                v_final_ms = car.v.x
                v_final_kmh = v_final_ms * 3.6 
                impulse = current_m * v_final_ms 
                
                if v_final_ms > 0:
                    result_txt.text = f"<h2 style='color: red;'><b>[💥 충돌 발생] {test_count}회차 - 충돌 속도: {v_final_kmh:.1f} km/h | 최종 충격량: {impulse:,.0f} N·s</b></h2>"
                    
                    # 단위를 kN·s로 환산 (/ 1000)
                    impulse_kn = impulse / 1000.0
                    
                    # [수정] 전체 250 스케일 안에서 낮은 값(14.6 등)도 뭉개지지 않고 확실한 기둥 형태를 갖추도록 하한 보정폭을 조절
                    final_plot_value = max(impulse_kn, 15.0)
                    
                    bar_chart.plot(test_count, final_plot_value)
                    test_count += 1
                
                running = False
                break
        
        if test_count > 10:
            result_txt.text = "<h3><b>[테스트 종료] 최대 테스트 횟수(10회)에 도달했습니다.</b></h3>"
