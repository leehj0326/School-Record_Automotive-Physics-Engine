# 4. 초기 물리 변수 설정
g = 9.8
m_val = 1500   
v_kmh = 50     
mu_val = 0.5   

running = False
has_run = False 
brake_start_x = 5.0 

START_FRONT_X = -25.0
car, current_front_offset = build_car(m_val, START_FRONT_X)
car.v = vec(0, 0, 0)

# 5. UI 컨트롤러 배치
scene.append_to_caption("<div style='clear:both;'></div>\n=== 제어판 ===\n\n")

def get_car_type(mass):
    if mass <= 1200: return "경차 (예: 모닝, 레이)"
    elif mass <= 1800: return "준중형/중형 세단 (예: 아반떼, 쏘나타)"
    elif mass <= 2500: return "대형 SUV/픽업트럭 (예: 팰리세이드, 카니발)"
    elif mass <= 5000: return "소형 트럭/마이크로버스 (예: 포터, 카운티)"
    elif mass <= 12000: return "대형 버스/중형 트럭 (예: 시내버스, 5톤 트럭)"
    else: return "대형 트럭/대형 덤프트럭 (25톤 카고 등)"

def set_mass(s):
    if running: return 
    global m_val, car, current_front_offset
    m_val = s.value
    car_type = get_car_type(m_val)
    car_type_txt.text = f"<span style='font-size: 12px; color: #666;'>[차종 가이드] {car_type}</span><br>"
    mass_txt.text = f" 차량 질량: {m_val:,} kg ({m_val/1000:.2f} t)"
    
    car.visible = False
    car, current_front_offset = build_car(m_val, START_FRONT_X)

def set_speed(s):
    global v_kmh  
    v_kmh = s.value
    speed_txt.text = f" 초기 속도: {v_kmh:>3} km/h"

def set_friction(s):
    global mu_val
    mu_val = s.value  
    fric_txt.text = f" 브레이크 강도(마찰 계수): {mu_val:.2f}"

def run_button(b):
    global running, has_run
    if not running:
        running = True
        has_run = True

def reset_button(b):
    global running, car, current_front_offset, test_count, has_run
    running = False 
    
    car.visible = False
    car, current_front_offset = build_car(m_val, START_FRONT_X)
    car.v = vec(0, 0, 0)
    
    # [수정] 초기화 시 x축 그래프 범위를 다음 정수 회차가 예쁘게 들어가도록 타이트하게 지정
    if has_run:
        test_count += 1
        impulse_graph.xmax = test_count + 0.5 
        has_run = False 
    
    result_txt.text = f"<h3><b>[테스트 결과] {test_count}회차 대기 중...</b></h3>"

button(text="▶ 테스트 시작", bind=run_button)
scene.append_to_caption("   ")
button(text="🔄 처음 위치로 초기화", bind=reset_button)
scene.append_to_caption("\n\n")

car_type = get_car_type(m_val)
car_type_txt = wtext(text=f"<span style='font-size: 12px; color: #666;'>[차종 가이드] {car_type}</span><br>")
mass_txt = wtext(text=f" 차량 질량: {m_val:,} kg ({m_val/1000:.2f} t)")
scene.append_to_caption("<br>")
slider(min=500, max=25000, value=1500, step=100, length=300, bind=set_mass)
scene.append_to_caption("\n\n")

speed_txt = wtext(text=f" 초기 속도: {v_kmh} km/h")
scene.append_to_caption("<br>")
slider(min=20, max=110, value=50, step=5, length=300, bind=set_speed)
scene.append_to_caption("\n\n")

fric_txt = wtext(text=f" 브레이크 강도(마찰 계수): {mu_val:.2f}")
scene.append_to_caption("<br>")
slider(min=0.0, max=2.5, value=0.5, step=0.05, length=300, bind=set_friction)
scene.append_to_caption("\n\n================\n")

result_txt = wtext(text="<h3><b>[테스트 결과] 1회차 대기 중...</b></h3>")

# 6. 메인 루프
dt = 0.01

while True:
    rate(100)
    
    if running:
        current_mu = mu_val 
        current_m = m_val
        
        v_ms = v_kmh / 3.6
        car.v = vec(v_ms, 0, 0)
        
        car.pos = vec(START_FRONT_X - current_front_offset, 0.3, 0)
        result_txt.text = f"<h3><b>[테스트 결과] {test_count}회차 진행 중...</b></h3>"
        
        while True:
            rate(100)
            
            if not running: break
            
            current_nose_x = car.pos.x + current_front_offset
            
            if current_nose_x >= brake_start_x:
                friction_force = -current_mu * current_m * g
                a_x = friction_force / current_m
                car.v.x = car.v.x + a_x * dt
                
                if car.v.x <= 0:
                    car.v.x = 0
                    result_txt.text = "<h2 style='color: green;'><b>[안전 정지] 벽에 부딪히기 전에 안전하게 멈췄습니다! (충격량: 0 N·s)</b></h2>"
                    
                    bar_chart.plot(test_count, 0) 
                    running = False
                    break 
            
            car.pos = car.pos + car.v * dt
            
            if current_nose_x >= wall.pos.x - 0.25:
                car.pos.x = (wall.pos.x - 0.25) - current_front_offset
                
                v_final_ms = car.v.x
                v_final_kmh = v_final_ms * 3.6 
                impulse = current_m * v_final_ms 
                
                if v_final_ms > 0:
                    result_txt.text = f"<h2 style='color: red;'><b>[💥 충돌 발생] 충돌 속도: {v_final_kmh:.1f} km/h | 최종 충격량: {impulse:,.0f} N·s</b></h2>"
                    
                    impulse_scaled = impulse / 10000.0
                    
                    if impulse_scaled > impulse_graph.ymax:
                        impulse_graph.ymax = impulse_scaled * 1.2
                        
                    bar_chart.plot(test_count, impulse_scaled) 
                
                running = False
                break
